#!/usr/bin/env bash
# repo-safety-scan — scan downloaded code for malicious patterns.
#
# Usage:
#   repo-safety-scan [repo|skill] <url-or-path> [--out <dir>] [--keep]
#
# Modes:
#   repo   (default) — general source-repo scan (gitleaks, semgrep, osv, guarddog)
#   skill           — agent-skill pack scan (Cisco skill-scanner primary)
#
# Flags:
#   --out <dir>   Write report+artifacts to <dir> (default: mktemp)
#   --keep        Don't delete the workdir on exit (useful for triage)
#   -h|--help     Show this help
#
# Principles:
#   - Never executes target code (no install/build/setup.py/postinstall).
#   - Clones with core.hooksPath=/dev/null; no submodules; shallow.
#   - Output: single markdown report with file:line evidence + verdict.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB_DIR="$SKILL_ROOT/lib"
MODES_DIR="$LIB_DIR/modes"
RULES_DIR="$SKILL_ROOT/rules"

SIZE_CAP_MB="${REPO_SAFETY_SCAN_SIZE_CAP_MB:-500}"
CLONE_DEPTH="${REPO_SAFETY_SCAN_CLONE_DEPTH:-50}"

usage() {
    sed -n '2,18p' "$0" | sed 's/^# \{0,1\}//'
}

log()  { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
warn() { printf '[%s] WARN: %s\n' "$(date +%H:%M:%S)" "$*" >&2; }
die()  { printf '[%s] ERROR: %s\n' "$(date +%H:%M:%S)" "$*" >&2; exit 1; }

resolve_gitdir_file() {
    local git_file="$1"
    python3 - "$git_file" <<'PY'
import sys
from pathlib import Path

git_file = Path(sys.argv[1])
try:
    text = git_file.read_text(encoding="utf-8", errors="replace")
except OSError:
    raise SystemExit(1)

for line in text.splitlines():
    line = line.strip()
    if line.lower().startswith("gitdir:"):
        rel_or_abs = line.split(":", 1)[1].strip()
        candidate = Path(rel_or_abs)
        if not candidate.is_absolute():
            candidate = (git_file.parent / candidate).resolve()
        print(candidate)
        raise SystemExit(0)

raise SystemExit(1)
PY
}

# -------- Arg parsing --------
MODE="repo"
TARGET=""
OUT_DIR=""
KEEP=0

# Allow first positional to be a mode OR a target
if [[ $# -gt 0 ]]; then
    case "$1" in
        -h|--help) usage; exit 0 ;;
        repo|skill) MODE="$1"; shift ;;
    esac
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        --out) OUT_DIR="$2"; shift 2 ;;
        --keep) KEEP=1; shift ;;
        --) shift; TARGET="${1:-}"; break ;;
        -*) die "unknown flag: $1" ;;
        *)
            if [[ -z "$TARGET" ]]; then TARGET="$1"
            else die "unexpected extra argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -n "$TARGET" ]] || { usage; exit 1; }

# -------- Workdir --------
if [[ -z "$OUT_DIR" ]]; then
    OUT_DIR="$(mktemp -d -t rss-XXXXXX)"
else
    mkdir -p "$OUT_DIR"
    OUT_DIR="$(cd "$OUT_DIR" && pwd)"
fi
WORK="$OUT_DIR"
SRC="$WORK/src"
ART="$WORK/artifacts"
mkdir -p "$ART"

cleanup() {
    if [[ "$KEEP" -eq 0 && "$OUT_DIR" == /tmp/rss-* ]]; then
        rm -rf "$OUT_DIR"
    fi
}
trap cleanup EXIT

log "mode=$MODE target=$TARGET work=$WORK"

# -------- Ingest --------
# Safe clone: disables git hooks, skips submodules, shallow depth, no tags.
ingest() {
    if [[ "$TARGET" =~ ^(https?|git|ssh|git\+ssh|git\+https?):// ]] || [[ "$TARGET" =~ ^git@ ]]; then
        log "cloning (shallow, no-submodules, hooks-off)..."
        GIT_TERMINAL_PROMPT=0 GIT_ASKPASS=/bin/echo \
            git -c core.hooksPath=/dev/null \
                -c protocol.version=2 \
                clone --depth="$CLONE_DEPTH" --no-tags --no-recurse-submodules \
                      --config core.hooksPath=/dev/null \
                      "$TARGET" "$SRC" 2>&1 | tee "$ART/clone.log" >&2
    elif [[ -d "$TARGET" ]]; then
        log "copying local path..."
        mkdir -p "$SRC"
        # rsync excluding .git/hooks executables from being copied into our workspace
        if command -v rsync >/dev/null 2>&1; then
            rsync -a --exclude='.git/hooks/*' "$TARGET/" "$SRC/"
        else
            cp -r "$TARGET/." "$SRC/"
            rm -rf "$SRC/.git/hooks" 2>/dev/null || true
        fi
        # Preserve worktree/submodule git metadata when the source checkout uses a
        # .git file that points at an external gitdir. Copy that gitdir into our
        # workspace so later scanners can inspect it.
        if [[ -f "$TARGET/.git" ]]; then
            local_gitdir="$(resolve_gitdir_file "$TARGET/.git" || true)"
            if [[ -n "${local_gitdir:-}" && -d "$local_gitdir" ]]; then
                rm -rf "$SRC/.git"
                mkdir -p "$SRC/.git"
                cp -a "$local_gitdir/." "$SRC/.git/"
            fi
        fi
    else
        die "target is neither a URL nor an existing directory: $TARGET"
    fi

    # Enforce size cap
    local du_mb
    du_mb="$(du -sm "$SRC" | awk '{print $1}')"
    if [[ "$du_mb" -gt "$SIZE_CAP_MB" ]]; then
        die "repo exceeds size cap ($du_mb MB > $SIZE_CAP_MB MB). Override with REPO_SAFETY_SCAN_SIZE_CAP_MB."
    fi
    log "ingested: $du_mb MB at $SRC"
}

ingest

# -------- Always-on: git metadata hostile-directive scan --------
if [[ -f "$LIB_DIR/git_metadata.py" ]]; then
    python3 "$LIB_DIR/git_metadata.py" "$SRC" > "$ART/git_metadata.json" 2>>"$ART/errors.log" || \
        warn "git_metadata scan exited non-zero"
fi

# -------- Mode dispatch --------
MODE_HANDLER="$MODES_DIR/${MODE}.sh"
[[ -x "$MODE_HANDLER" || -f "$MODE_HANDLER" ]] || die "mode handler not found: $MODE_HANDLER"

export RSS_SRC="$SRC"
export RSS_ART="$ART"
export RSS_RULES="$RULES_DIR"
export RSS_MODE="$MODE"

log "running mode handler: $MODE"
bash "$MODE_HANDLER" || warn "mode handler $MODE exited non-zero (continuing to render)"

# -------- Auto-detect hint: repo mode, but looks like a skill pack --------
if [[ "$MODE" == "repo" ]]; then
    if [[ -d "$SRC/.claude/skills" || -d "$SRC/.claude/commands" || -d "$SRC/.cursor/rules" ]] \
       || find "$SRC" -maxdepth 3 -name "SKILL.md" -print -quit 2>/dev/null | grep -q .; then
        echo "hint: target appears to contain agent-skill content — consider re-running with: repo-safety-scan skill <target>" > "$ART/mode_hint.txt"
    fi
fi

# -------- Render report --------
REPORT="$WORK/report.md"
python3 "$LIB_DIR/render_report.py" --mode "$MODE" --target "$TARGET" --artifacts "$ART" > "$REPORT"

echo
echo "Report:  $REPORT"
echo "Workdir: $WORK"
if [[ -f "$ART/mode_hint.txt" ]]; then
    echo
    cat "$ART/mode_hint.txt"
fi

# Keep the workdir so the caller can read the report and artifacts.
KEEP=1
